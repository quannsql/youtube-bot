OPENAI_API_KEY=sk_replace_openai_platform_key

# Text planning uses the official Responses API. gpt-5.4-mini is eligible for
# complimentary shared-traffic tokens when data sharing is enabled for this Project.
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_TEXT_REASONING_EFFORT=low
OPENAI_TEXT_LONG_FORM_REASONING_EFFORT=medium
OPENAI_TEXT_MAX_OUTPUT_TOKENS=16000
OPENAI_TEXT_ATTEMPTS=3
OPENAI_TEXT_RETRY_BACKOFF_SECONDS=5
OPENAI_TEXT_CONNECT_TIMEOUT_SECONDS=30
OPENAI_TEXT_READ_TIMEOUT_SECONDS=300

# Optional: when set, Brave Images supplies up to 2 Short visuals and 5 long-form
# visuals. Long-form keeps a hard cap of 10 GPT Image 2 calls; missing Brave slots
# reuse an existing visual instead of spending more OpenAI credits.
BRAVE_SEARCH_API_KEY=
BRAVE_WEB_IMAGES_PER_SHORT=2
BRAVE_WEB_IMAGES_PER_LONG_FORM=5

# GPT Image 2 is fixed in code to quality=low and the documented ~$0.005 sizes:
# 1024x1536 portrait / 1536x1024 landscape. No quality override is exposed.
OPENAI_IMAGE_ATTEMPTS=3
OPENAI_IMAGE_RETRY_BACKOFF_SECONDS=10
IMAGE_CONNECT_TIMEOUT_SECONDS=30
IMAGE_READ_TIMEOUT_SECONDS=180
ALLOW_IMAGE_FALLBACK_PLACEHOLDER=false

# Local default: generated/, shorts.db and the JSON credential files remain here.
# Railway automatically supplies RAILWAY_VOLUME_MOUNT_PATH; do not set this there.
BOT_DATA_DIR=.

# Google Cloud Text-to-Speech (Chirp 3 HD). This is a service-account JSON FILE,
# not an API-key string. Keep the downloaded file in the project root.
GOOGLE_TTS_SERVICE_ACCOUNT_FILE=google_tts_service_account.json
GOOGLE_TTS_VOICE=en-US-Chirp3-HD-Achernar
GOOGLE_TTS_SPEAKING_RATE=1.05
SOCIAL_TTS_VOICE=vi-VN-Standard-A
SOCIAL_TTS_SPEAKING_RATE=1.05

# Required only when publishing. Obtain this OAuth desktop-app JSON from Google Cloud
YOUTUBE_CLIENT_SECRETS=client_secrets.json
YOUTUBE_TOKEN_FILE=youtube_token.json
# private is a safe first run; use unlisted or public when ready.
YOUTUBE_PRIVACY_STATUS=private

# Optional social publishing. YouTube keeps English narration; Facebook/TikTok use
# a Vietnamese narration rendered to generated/.../short_vi.mp4.
PUBLISH_FACEBOOK=false
FACEBOOK_GRAPH_VERSION=v25.0
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
# Optional: long-lived user token. If PAGE_ACCESS_TOKEN is empty or expired,
# the bot can fetch the matching Page token from /me/accounts.
FACEBOOK_USER_ACCESS_TOKEN=

PUBLISH_TIKTOK=false
TIKTOK_ACCESS_TOKEN=
TIKTOK_PRIVACY_LEVEL=SELF_ONLY
TIKTOK_DISABLE_DUET=false
TIKTOK_DISABLE_COMMENT=false
TIKTOK_DISABLE_STITCH=false

# Railway fallback when SFTP Volume upload is unavailable. Put Base64-encoded JSON
# values in Railway Variables only; do not add them to local .env or GitHub.
# GOOGLE_TTS_SERVICE_ACCOUNT_JSON_B64=
# YOUTUBE_CLIENT_SECRETS_JSON_B64=
# YOUTUBE_TOKEN_JSON_B64=

# Content defaults
SHORT_LANGUAGE=en
SHORT_DURATION_SECONDS=60
SCHEDULED_DAILY_LIMIT=2

# Long-form horizontal videos run end-to-end once every two local calendar days.
# Set BOT_RUN_MODE=long-form only on the separate Railway long-form service.
# BOT_RUN_MODE=long-form
LONG_FORM_MIN_DURATION_SECONDS=300
LONG_FORM_MAX_DURATION_SECONDS=420
LONG_FORM_TIMEZONE=Asia/Bangkok
LONG_FORM_INTERVAL_DAYS=2
