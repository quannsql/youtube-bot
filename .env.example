OPENAI_API_KEY=sk_replace_openai_platform_key

# Text planning uses the official Responses API. gpt-5.4-mini is eligible for
# complimentary shared-traffic tokens when data sharing is enabled for this Project.
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_TEXT_REASONING_EFFORT=low
OPENAI_TEXT_LONG_FORM_REASONING_EFFORT=medium
OPENAI_TEXT_MAX_OUTPUT_TOKENS=16000
OPENAI_TEXT_ATTEMPTS=3
OPENAI_TEXT_RETRY_BACKOFF_SECONDS=5
OPENAI_TEXT_CONNECT_TIMEOUT_SECONDS=30
OPENAI_TEXT_READ_TIMEOUT_SECONDS=300

# Optional: when set, Brave Images supplies up to 2 Short visuals. Long-form is a
# cartoon stick-figure explainer channel, so it defaults to 0 forced Brave slots and
# generates every beat as a cartoon stick-figure illustration; a real photo is fetched
# only for scenes the planner tags with a search_query (a famous real place/landmark/artifact).
BRAVE_SEARCH_API_KEY=
BRAVE_WEB_IMAGES_PER_SHORT=2
BRAVE_WEB_IMAGES_PER_LONG_FORM=0
# Number of AI (cartoon stick-figure) images per long-form video = number of scenes.
# More images means a tighter match to the narration. Default 15 (max 30).
LONG_FORM_AI_IMAGES=15
# Brave commonly enforces a one-second sliding request window. Keep searches
# slightly farther apart and retry transient HTTP 429 responses.
BRAVE_SEARCH_MIN_INTERVAL_SECONDS=2.0
BRAVE_SEARCH_ATTEMPTS=3

# GPT Image 2 is fixed in code to quality=low and the documented ~$0.005 sizes:
# 1024x1536 portrait / 1536x1024 landscape. No quality override is exposed.
OPENAI_IMAGE_ATTEMPTS=3
OPENAI_IMAGE_RETRY_BACKOFF_SECONDS=10
IMAGE_CONNECT_TIMEOUT_SECONDS=30
IMAGE_READ_TIMEOUT_SECONDS=180
ALLOW_IMAGE_FALLBACK_PLACEHOLDER=false

# Transparent brand logo rendered at the top-right of every final video.
OVERLAY_LOGO_FILE=overlay-logo.png
OVERLAY_LOGO_SHORT_WIDTH=220
OVERLAY_LOGO_LONG_FORM_WIDTH=220
OVERLAY_LOGO_MARGIN=36
OVERLAY_LOGO_SHORT_TOP_MARGIN=72
OVERLAY_LOGO_LONG_FORM_TOP_MARGIN=36

# Small muted video rendered at the bottom-right of every final Short and social
# video. Long-form videos no longer use it (logo overlay only), so
# OVERLAY_VIDEO_LONG_FORM_WIDTH is unused. Relative paths are resolved from the
# application root, so this tracked asset is bundled into every Railway deployment.
OVERLAY_VIDEO_FILE=assets/overlay-video.mp4
OVERLAY_VIDEO_SHORT_WIDTH=180
OVERLAY_VIDEO_LONG_FORM_WIDTH=160
OVERLAY_VIDEO_RIGHT_MARGIN=96
OVERLAY_VIDEO_BOTTOM_MARGIN=36
OVERLAY_VIDEO_CORNER_RADIUS=18
OVERLAY_VIDEO_LOOP_GAP_SECONDS=5

# Local default: generated/, shorts.db and the JSON credential files remain here.
# Railway automatically supplies RAILWAY_VOLUME_MOUNT_PATH; do not set this there.
BOT_DATA_DIR=.

# English Short/Long narration via Google Cloud Chirp 3 HD (female voice).
GOOGLE_TTS_SERVICE_ACCOUNT_FILE=google_tts_service_account.json
GOOGLE_TTS_VOICE=en-US-Chirp3-HD-Leda
GOOGLE_TTS_SPEAKING_RATE=1.05
# Vietnamese Facebook/TikTok narration via OpenAI gpt-4o-mini-tts.
SOCIAL_OPENAI_TTS_VOICE=nova
SOCIAL_OPENAI_TTS_SPEED=1.0

# Required only when publishing. Obtain this OAuth desktop-app JSON from Google Cloud
YOUTUBE_CLIENT_SECRETS=client_secrets.json
YOUTUBE_TOKEN_FILE=youtube_token.json
# private is a safe first run; use unlisted or public when ready.
YOUTUBE_PRIVACY_STATUS=private

# Optional social publishing. YouTube keeps English narration; Facebook/TikTok use
# a Vietnamese narration rendered to generated/.../short_vi.mp4.
PUBLISH_FACEBOOK=false
FACEBOOK_GRAPH_VERSION=v25.0
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
# Optional: long-lived user token. If PAGE_ACCESS_TOKEN is empty or expired,
# the bot can fetch the matching Page token from /me/accounts.
FACEBOOK_USER_ACCESS_TOKEN=

PUBLISH_TIKTOK=false
TIKTOK_ACCESS_TOKEN=
TIKTOK_PRIVACY_LEVEL=SELF_ONLY
TIKTOK_DISABLE_DUET=false
TIKTOK_DISABLE_COMMENT=false
TIKTOK_DISABLE_STITCH=false

# Railway fallback when SFTP Volume upload is unavailable. Put Base64-encoded JSON
# values in Railway Variables only; do not add them to local .env or GitHub.
# GOOGLE_TTS_SERVICE_ACCOUNT_JSON_B64=
# YOUTUBE_CLIENT_SECRETS_JSON_B64=
# YOUTUBE_TOKEN_JSON_B64=

# Content defaults
SHORT_LANGUAGE=en
SHORT_DURATION_SECONDS=60
SCHEDULED_DAILY_LIMIT=2

# Long-form horizontal videos run end-to-end once every two local calendar days.
# Set BOT_RUN_MODE=long-form only on the separate Railway long-form service.
# BOT_RUN_MODE=long-form
LONG_FORM_MIN_DURATION_SECONDS=300
LONG_FORM_MAX_DURATION_SECONDS=420
LONG_FORM_TIMEZONE=Asia/Bangkok
LONG_FORM_INTERVAL_DAYS=2

# Manual idea frontend (web_app.py). Runs as its OWN always-on Railway service:
#   start command:  python web_app.py
# It shares the same Postgres (DATABASE_URL) and credentials as the auto services.
# WEB_ACCESS_TOKEN gates the page (needed because each submit spends API credits and
# uploads to your YouTube). Leave empty ONLY for local testing (page becomes open).
WEB_ACCESS_TOKEN=
# Signs the login session cookie. Set a long random string on Railway so logins
# survive restarts; if empty a random one is generated per boot (re-login needed).
FLASK_SECRET_KEY=
# Railway supplies PORT automatically; locally the page serves on 8080.
# WEB_WORKER_POLL_SECONDS=3
